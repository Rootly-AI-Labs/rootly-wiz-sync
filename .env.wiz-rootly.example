WIZ_CLIENT_ID=replace-me
WIZ_CLIENT_SECRET=replace-me
WIZ_AUTH_URL=https://auth.app.wiz.io/oauth/token
WIZ_API_URL=https://api.us17.app.wiz.io/graphql
# Required scope for default query: read:issues

# Rootly incoming webhook endpoint
ROOTLY_WEBHOOK_URL=https://example.rootly.webhook/url

# Optional auth for webhook delivery:
# ROOTLY_WEBHOOK_BEARER_TOKEN=replace-me
# ROOTLY_WEBHOOK_AUTH_HEADER=X-Api-Key
# ROOTLY_WEBHOOK_AUTH_VALUE=replace-me

# Optional tuning
POLL_INTERVAL_SECS=86400
WIZ_PAGE_SIZE=50
WIZ_MAX_PAGES=5
WIZ_MAX_RPS=3
WIZ_MAX_RETRIES=5
WIZ_TOKEN_REFRESH_RETRIES=5
WIZ_RETRY_BASE_SECS=1.0
WIZ_RETRY_MAX_SECS=30.0
REQUEST_TIMEOUT_SECS=20

# Optional filtering
WIZ_MATCH_KEYWORDS=vulnerability,threat,cve,detection
# WIZ_ONLY_SEVERITIES=critical,high
# WIZ_FILTER_BY_JSON={"status":["OPEN","IN_PROGRESS"]}
# WIZ_ORDER_BY_JSON={"field":"UPDATED_AT","direction":"DESC"}

# Optional state location
WIZ_STATE_FILE=.wiz_rootly_seen_ids.json
