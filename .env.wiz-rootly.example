# Minimal required values:
WIZ_CLIENT_ID=replace-me
WIZ_CLIENT_SECRET=replace-me
WIZ_AUTH_URL=https://auth.app.wiz.io/oauth/token
WIZ_API_URL=https://api.us17.app.wiz.io/graphql
WIZ_USER_AGENT=Rootly-Wiz-Sync-1.0
# Required scope for default query: read:issues

# Recommended setup:
# 1. Set WIZ_CLIENT_ID and WIZ_CLIENT_SECRET
# 2. Run `python3 wiz_to_rootly.py bootstrap-rootly --rootly-api-token <token> --write-env`
# 3. Validate with `python3 wiz_to_rootly.py validate`
# 4. Schedule `python3 wiz_to_rootly.py sync` once per day

# Rootly incoming webhook endpoint (filled automatically by bootstrap-rootly --write-env)
ROOTLY_WEBHOOK_URL=https://example.rootly.webhook/url

# Optional auth for webhook delivery:
# ROOTLY_WEBHOOK_BEARER_TOKEN=replace-me
# ROOTLY_WEBHOOK_AUTH_HEADER=X-Api-Key
# ROOTLY_WEBHOOK_AUTH_VALUE=replace-me

# Optional Rootly bootstrap settings:
# ROOTLY_API_TOKEN=replace-me
# ROOTLY_API_URL=https://api.rootly.com
# ROOTLY_ALERT_SOURCE_NAME=Wiz Security Alerts
# ROOTLY_ALERT_SOURCE_ID=src_123
# ROOTLY_OWNER_GROUP_IDS=grp_123,grp_456
# Run `python3 wiz_to_rootly.py bootstrap-rootly --rootly-api-token <token> --write-env`
# to populate ROOTLY_WEBHOOK_URL and ROOTLY_ALERT_SOURCE_ID automatically.

# Optional tuning
POLL_INTERVAL_SECS=86400
WIZ_PAGE_SIZE=50
WIZ_MAX_PAGES=5
WIZ_MAX_RPS=2
WIZ_MAX_RETRIES=5
WIZ_TOKEN_REFRESH_RETRIES=5
WIZ_RETRY_BASE_SECS=1.0
WIZ_RETRY_MAX_SECS=30.0
REQUEST_TIMEOUT_SECS=20
ROOTLY_MAX_RPS=1
ROOTLY_MAX_RETRIES=5
ROOTLY_RETRY_BASE_SECS=1.0
ROOTLY_RETRY_MAX_SECS=30.0

# Optional filtering
# WIZ_MATCH_KEYWORDS=vulnerability,threat,cve,detection
# WIZ_ONLY_SEVERITIES=critical,high
# WIZ_FILTER_BY_JSON={"status":["OPEN","IN_PROGRESS","RESOLVED","CLOSED","REJECTED"]}
# WIZ_ORDER_BY_JSON={"field":"UPDATED_AT","direction":"DESC"}  # optional
# WIZ_RESOLVED_STATUSES=resolved,closed,rejected

# Default delta behavior:
# - first run with no successful-run cursor: {"status":["OPEN","IN_PROGRESS"]}
# - later runs: {"statusChangedAt":{"after":"<last_successful_run_at>"}}
# - if you set WIZ_FILTER_BY_JSON, the bridge still adds statusChangedAt.after after the first
#   successful run unless you explicitly provide statusChangedAt yourself.

# Optional state location
WIZ_STATE_FILE=.wiz_rootly_seen_ids.json

# Validate locally before your first dry-run:
# python3 wiz_to_rootly.py validate
